{
  "name": "daemond",
  "version": "0.1.4",
  "description": "Seed launcher script for idempotent local command daemons",
  "author": "ComputeSDK",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist dist-runtime && tsc -p tsconfig.runtime.json && tsc && cp -r dist-runtime dist/runtime",
    "dev": "tsc --watch",
    "lint": "eslint",
    "test:integration": "pnpm run build && node --test test/integration/seed-script.test.cjs",
    "test:integration:docker": "pnpm run build && node test/integration/docker-seed-script.mjs",
    "typecheck": "tsc -p tsconfig.runtime.json --noEmit && tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "daemon",
    "seed",
    "ipc",
    "unix-socket",
    "sse"
  ],
  "devDependencies": {
    "@computesdk/docker": "workspace:*",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.37.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/computesdk/computesdk.git",
    "directory": "packages/daemond"
  },
  "homepage": "https://www.computesdk.com",
  "bugs": {
    "url": "https://github.com/computesdk/computesdk/issues"
  }
}
