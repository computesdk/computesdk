{
    "name": "@computesdk/dimension",
    "version": "0.1.0",
    "description": "ComputeSDK provider for Dimension Runtime — Platform with sub-7ms cold-start",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
          ".": {
                  "types": "./dist/index.d.ts",
                  "import": "./dist/index.js"
          }
    },
    "scripts": {
          "build": "tsup",
          "clean": "rimraf dist",
          "typecheck": "tsc --noEmit"
    },
    "keywords": [
          "computesdk",
          "sandbox",
          "dimension",
          "deterministic",
          "runtime",
          "cold-start"
    ],
    "peerDependencies": {
          "@computesdk/provider": ">=0.1.0"
    },
    "devDependencies": {
          "typescript": "^5.0.0"
    },
    "license": "MIT",
    "repository": {
          "type": "git",
          "url": "https://github.com/computesdk/computesdk",
          "directory": "packages/dimension"
    }
}
